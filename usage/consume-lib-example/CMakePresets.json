{
  "version": 10,
  "configurePresets": [
    {
      "name": "default",
      "hidden": true,
      "binaryDir": "build/${presetName}",
      "installDir": "build/install/${presetName}",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "${sourceDir}/build/install",
        "CMAKE_VERIFY_INTERFACE_HEADER_SETS": true
      }
    },
    {
      "name": "ci",
      "inherits": [
        "default"
      ]
    }
  ],
  "buildPresets": [
    {
      "name": "ci",
      "configurePreset": "ci",
      "configuration": "Debug",
      "targets": [
        "all"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "ci",
      "configurePreset": "ci",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true,
        "subprojectSummary": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "ci",
      "steps": [
        {
          "type": "configure",
          "name": "ci"
        },
        {
          "type": "build",
          "name": "ci"
        },
        {
          "type": "test",
          "name": "ci"
        }
      ]
    }
  ]
}