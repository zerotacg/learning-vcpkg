@PACKAGE_INIT@
include(CMakeFindDependencyMacro)

set(_@PROJECT_NAME@_supported_components @package_components@)
set(_@PROJECT_NAME@_hello-world_dependencies "@component_hello-world_dependencies@")
set(_@PROJECT_NAME@_hello-world_component_dependencies "@component_hello-world_component_dependencies@")
set(_@PROJECT_NAME@_example_dependencies "@component_example_dependencies@")


function(find_component _comp)
    foreach(_dependency IN ITEMS ${_@PROJECT_NAME@_${_comp}_dependencies})
        find_dependency(${_dependency})
    endforeach()

    foreach(_dependency IN ITEMS ${_@PROJECT_NAME@_${_comp}_component_dependencies})
        find_component(${_dependency})
    endforeach()

    include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@-${_comp}-targets.cmake")
    set(@PROJECT_NAME@_${_comp}_FOUND True)
endfunction()

foreach(_comp ${@PROJECT_NAME@_FIND_COMPONENTS})
    if (NOT _comp IN_LIST _@PROJECT_NAME@_supported_components)
        set(@PROJECT_NAME@_FOUND False)
        set(@PROJECT_NAME@_NOT_FOUND_MESSAGE "Unsupported component: ${_comp}")
    else()
        find_component(${_comp})
    endif()
endforeach()

check_required_components(@PROJECT_NAME@)
